#!/usr/bin/env bash
# claude-composer-run — safe launch that captures workspace immediately then execs claude
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/composer-workspace.sh"
composer_capture_workspace
# Reuse the provider setup so this command is a complete one-shot launcher, not merely a header wrapper.
# shellcheck source=claude-composer.sh
source "${SCRIPT_DIR}/claude-composer.sh" on
exec claude "$@"
