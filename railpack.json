{
  "$schema": "https://schema.railpack.com",
  "provider": "golang",
  "packages": {
    "go": "1.26",
    "node": "22"
  },
  "buildAptPackages": [
    "g++",
    "make",
    "python3"
  ],
  "steps": {
    "build": {
      "commands": [
        "...",
        "cp out cli-proxy-api && chmod +x cli-proxy-api",
        "cd sidecars/cursor-bridge && npm ci && npm test && npm run selftest"
      ]
    }
  },
  "deploy": {
    "startCommand": "bash scripts/railway_start.sh",
    "variables": {
      "BAKED_SERVER_REQUIRED": "1",
      "NODE_ENV": "production"
    },
    "aptPackages": [
      "bash",
      "ca-certificates",
      "curl",
      "gzip",
      "libasound2",
      "libatk-bridge2.0-0",
      "libatk1.0-0",
      "libcups2",
      "libdrm2",
      "libgbm1",
      "libgtk-3-0",
      "libnss3",
      "libpangocairo-1.0-0",
      "libx11-xcb1",
      "libxcomposite1",
      "libxdamage1",
      "libxext6",
      "libxi6",
      "libxkbcommon0",
      "libxrandr2",
      "libxshmfence1",
      "libxss1",
      "libxtst6",
      "libxcb1",
      "libxfixes3",
      "libxrender1",
      "libxcursor1",
      "libxinerama1",
      "libxau6",
      "libxdmcp6",
      "gnupg",
      "tar",
      "unzip",
      "wget"
    ]
  }
}
